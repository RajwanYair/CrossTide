# CrossTide Docker environment variables
#
# Copy this file to .env and fill in your API keys:
#   cp docker/.env.example .env
#
# All keys are optional — the app works without them using free-tier providers.

# Port to expose the CrossTide API + frontend (default: 8787)
PORT=8787

# Finnhub API key — enables real-time quotes and candle data
# Get a free key at https://finnhub.io/register
FINNHUB_KEY=

# FRED API key — enables economic data series (VIX, Treasury rates, etc.)
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_KEY=
