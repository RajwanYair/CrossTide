{
  "ignorePatterns": [
    { "pattern": "^http://localhost" },
    { "pattern": "^https?://127\\.0\\.0\\.1" },
    { "pattern": "^mailto:" },
    { "pattern": "^#" },
    { "pattern": "example\\.com" },
    { "pattern": "^https://localhost" }
  ],
  "replacementPatterns": [{ "pattern": "^/", "replacement": "{{BASEURL}}/" }],
  "httpHeaders": [
    {
      "urls": ["https://github.com", "https://docs.github.com"],
      "headers": {
        "Accept": "text/html",
        "User-Agent": "CrossTide-link-check"
      }
    }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 2,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 206, 301, 302, 307, 308, 403]
}
