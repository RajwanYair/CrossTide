{
  "name": "crosstide",
  "version": "4.0.0",
  "description": "CrossTide Web — Browser-based stock monitoring dashboard with 12-method consensus signals, interactive charting, and offline-first PWA.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:css": "stylelint \"src/**/*.css\" --max-warnings 0",
    "lint:html": "htmlhint index.html",
    "lint:md": "markdownlint-cli2 \"*.md\" \"docs/**/*.md\" \".github/**/*.md\"",
    "lint:all": "npm run lint && npm run lint:css && npm run lint:html && npm run lint:md",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "ci": "npm run typecheck && npm run lint:all && npm run test:coverage && npm run build && npm run check:bundle",
    "clean": "rimraf dist coverage"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "htmlhint": "^1.5.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.5.0",
    "rimraf": "^6.0.0",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
