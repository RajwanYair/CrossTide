{
  "name": "crosstide",
  "version": "11.43.0",
  "description": "CrossTide Web — browser-based stock monitoring dashboard with 12-method consensus signals, interactive charting, and offline-first PWA.",
  "type": "module",
  "private": true,
  "workspaces": [
    "docs-site"
  ],
  "exports": {
    ".": "./src/main.ts",
    "./core": "./src/core/index.ts",
    "./domain": "./src/domain/index.ts",
    "./cards": "./src/cards/index.ts",
    "./ui": "./src/ui/index.ts"
  },
  "homepage": "https://github.com/RajwanYair/CrossTide",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RajwanYair/CrossTide.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "vite",
    "dev:components": "vite docs/components-preview.html",
    "build": "tsc --noEmit && tsc --project tsconfig.sw.json --noEmit && vite build && node scripts/workbox-inject.mjs",
    "build:sourcemaps": "npm run build && node scripts/upload-sourcemaps.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "lhci": "lhci autorun --config config/lighthouserc.json",
    "lint": "eslint . --max-warnings 0",
    "lint:css": "stylelint \"src/**/*.css\" --config config/.stylelintrc.json --max-warnings 0",
    "lint:html": "htmlhint index.html --config config/.htmlhintrc",
    "lint:md": "markdownlint-cli2 --config config/.markdownlint.json \"**/*.md\" \"#**/node_modules/**\" \"#dist\" \"#coverage\" \"#build\" \"#test-results\" \"#playwright-report\" \"#docs/INDICATORS.md\" \"#docs/ROADMAP-v6-archive.md\" \"#docs/ROADMAP-v8-archive.md\" \"#docs/ROADMAP-v9-archive.md\"",
    "lint:all": "npm run lint && npm run lint:css && npm run lint:html && npm run lint:md && npm run format:check",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.sw.json --noEmit",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:wasm": "node scripts/check-wasm-size.mjs",
    "check:contrast": "node scripts/check-contrast.mjs",
    "check:supply-chain": "npm audit --omit=dev --audit-level=high && npm audit signatures",
    "gen:csp": "node scripts/gen-csp.mjs",
    "gen:api-types": "node --experimental-strip-types scripts/gen-openapi-client.mjs",
    "gen:indicator-docs": "tsx scripts/generate-indicator-docs.ts",
    "audit:jsdoc": "node scripts/audit-jsdoc.mjs",
    "ci": "npm run typecheck && npm run lint:all && npm run test:coverage && npm run build && npm run check:bundle",
    "test:mutate": "npx stryker run --configFile config/stryker.config.mjs",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "record:demos": "tsx scripts/record-demos.ts",
    "clean": "node scripts/clean.mjs",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "commit-msg": "npx commitlint --config config/commitlint.config.mjs --edit $1",
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,mjs}": [
      "eslint --max-warnings 0 --no-warn-ignored --fix",
      "biome format --write"
    ],
    "*.css": [
      "stylelint --config config/.stylelintrc.json --max-warnings 0 --fix",
      "biome format --write"
    ],
    "*.{md,json,html}": [
      "biome format --write"
    ]
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.59.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "fast-check": "^4.7.0",
    "happy-dom": "^20.9.0",
    "htmlhint": "^1.9.2",
    "https-proxy-agent": "^9.0.0",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "playwright": "^1.59.1",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.4",
    "workbox-background-sync": "^7.4.0",
    "workbox-build": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-navigation-preload": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "dependencies": {
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@js-temporal/polyfill": "^0.5.1",
    "hono": "^4.12.24",
    "lightweight-charts": "^5.2.0",
    "lit-html": "^3.3.3",
    "morphdom": "^2.7.8",
    "valibot": "^1.4.1"
  }
}
