# CrossTide — Environment Variables
# Copy to .env.local and fill in values (never commit .env.local).

# ── GitHub Pages base path ─────────────────────────────────────────
# Set automatically in CI. Leave blank for local dev (defaults to /).
# VITE_BASE=/CrossTide/

# ── Telemetry (F5) ────────────────────────────────────────────────
# Plausible analytics — self-hosted instance URL and registered site.
VITE_PLAUSIBLE_URL=
VITE_PLAUSIBLE_SITE=

# GlitchTip error tracking — Sentry-compatible DSN.
VITE_GLITCHTIP_DSN=

# ── Worker API ─────────────────────────────────────────────────────
# Override the Cloudflare Worker base URL for local dev.
# VITE_WORKER_BASE_URL=http://localhost:8787

# ── Shared dev-tool caches (optional) ──────────────────────────────
# Redirect heavy dev caches into a shared parent directory (e.g. ../MyScripts/cache)
# to avoid duplicating Playwright browsers / Wrangler state across sibling
# CrossTide-family projects. See ../MyScripts/README.md.
# PLAYWRIGHT_BROWSERS_PATH=../MyScripts/cache/playwright
# WRANGLER_HOME=../MyScripts/cache/wrangler
# npm_config_cache=../MyScripts/cache/npm
# GH_CONFIG_DIR=../MyScripts/cache/gh

# ── Intermediate output redirects (optional) ───────────────────────
# Send Vitest coverage to %TEMP% (or any path) instead of the repo's coverage/.
# Useful to keep the working tree clean during local dev. CI leaves it unset.
# VITEST_COVERAGE_DIR=%TEMP%\crosstide\coverage
# PW_TEST_OUTPUT_DIR=%TEMP%\crosstide\test-results
