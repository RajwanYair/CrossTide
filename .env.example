# CrossTide — Environment Variables
# Copy to .env.local and fill in values (never commit .env.local).

# ── GitHub Pages base path ─────────────────────────────────────────
# Set automatically in CI. Leave blank for local dev (defaults to /).
# VITE_BASE=/CrossTide/

# ── Telemetry (F5) ────────────────────────────────────────────────
# Plausible analytics — self-hosted instance URL and registered site.
VITE_PLAUSIBLE_URL=
VITE_PLAUSIBLE_SITE=

# GlitchTip error tracking — Sentry-compatible DSN.
VITE_GLITCHTIP_DSN=

# ── Worker API ─────────────────────────────────────────────────────
# Override the Cloudflare Worker base URL for local dev.
# VITE_WORKER_BASE_URL=http://localhost:8787
