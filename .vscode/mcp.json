{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "gallery": true
    },
    "cloudflare": {
      "type": "stdio",
      "command": "npx",
      "args": ["mcp-remote", "https://mcp.cloudflare.com/sse"],
      "gallery": true
    },
    "gitkraken": {
      "type": "stdio",
      "command": "npx",
      "args": ["gitkraken-mcp-server"],
      "gallery": true
    }
  }
}
