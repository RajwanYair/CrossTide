{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CrossTide (Windows)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "args": ["-d", "windows"]
    },
    {
      "name": "CrossTide (Android)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "android"
      ]
    },
    {
      "name": "CrossTide (Profile)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "profile"
    },
    {
      "name": "Run Tests",
      "type": "dart",
      "request": "launch",
      "program": "test"
    },
    {
      "name": "Run Tests with Coverage",
      "type": "dart",
      "request": "launch",
      "program": "test",
      "args": [
        "--coverage"
      ]
    }
  ]
}
