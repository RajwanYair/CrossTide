{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "flutter: pub get",
      "type": "shell",
      "command": "flutter pub get",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "flutter: build_runner",
      "type": "shell",
      "command": "dart run build_runner build --delete-conflicting-outputs",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "flutter: build_runner watch",
      "type": "shell",
      "command": "dart run build_runner watch --delete-conflicting-outputs",
      "group": "build",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "flutter: analyze",
      "type": "shell",
      "command": "flutter analyze --fatal-infos",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "flutter: test",
      "type": "shell",
      "command": "flutter test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "flutter: format check",
      "type": "shell",
      "command": "dart format --set-exit-if-changed lib test",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "flutter: build windows",
      "type": "shell",
      "command": "flutter build windows",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "flutter: test coverage",
      "type": "shell",
      "command": "flutter test --coverage --timeout 30s",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "flutter: format",
      "type": "shell",
      "command": "dart format lib test",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "flutter: build android debug",
      "type": "shell",
      "command": "flutter build apk --debug",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "dev: full health check",
      "type": "shell",
      "command": "flutter analyze --fatal-infos && dart format --set-exit-if-changed lib test && flutter test --coverage --timeout 30s",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "dev: domain coverage check",
      "type": "shell",
      "command": "flutter test --coverage --timeout 30s && powershell -NoProfile -Command \"$c=Get-Content coverage/lcov.info;$in=$false;$u=0;foreach($l in $c){if($l -match '^SF:lib\\\\src\\\\domain\\\\'){$in=$true}elseif($l -eq 'end_of_record'){$in=$false}elseif($in -and $l -match '^DA:\\d+,0$'){$u++}};if($u -gt 0){Write-Error \"Domain coverage gap: $u uncovered lines\";exit 1}else{Write-Host 'Domain: 100% covered'}\"",
      "group": "test",
      "detail": "Runs tests with coverage then verifies domain layer is 100% covered",
      "problemMatcher": []
    },
    {
      "label": "dev: pre-commit run all",
      "type": "shell",
      "command": "pre-commit run --all-files",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "release: bump patch",
      "type": "shell",
      "command": "gh workflow run bump-version.yml -f bump=patch",
      "group": "build",
      "problemMatcher": [],
      "detail": "Requires GitHub CLI (gh) to be installed and authenticated"
    },
    {
      "label": "release: bump minor",
