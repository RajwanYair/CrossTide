      "group": "build",
      "problemMatcher": [],
      "detail": "Requires GitHub CLI (gh) to be installed and authenticated"
    },
    {
      "label": "release: bump major",
      "type": "shell",
      "command": "gh workflow run bump-version.yml -f bump=major",
      "group": "build",
      "problemMatcher": [],
